# Firebase (Firestore)
# 방법 1: 개별 항목 (Vercel 권장 — JSON 붙여넣기 오류 방지)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# 방법 2: 서비스 계정 JSON 전체 (한 줄)
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# 기본 DB가 아닌 이름 있는 DB를 쓸 때만 설정
# 로컬 개발 시 프로덕션 DB와 분리하려면 Firebase Console에서 'dev' DB를 만든 뒤 아래 설정
# FIRESTORE_DATABASE_ID=dev

# 로컬에서만 샘플 프로젝트 3개 자동 생성 (프로덕션에는 적용되지 않음)
SEED_SAMPLE_DATA=true

# Vercel Blob (이미지 업로드, 프로덕션)
# 로컬 개발 시 없으면 public/uploads 폴더에 저장됩니다
BLOB_READ_WRITE_TOKEN=

# OG / 공유 미리보기용 사이트 URL (프로덕션 도메인)
# 예: https://ui-project-hub.vercel.app
NEXT_PUBLIC_SITE_URL=
